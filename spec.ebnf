(* =========================
   Top-level structure
   ========================= *)

spec-file =
    block,
    { empty-line, block } ;

(* A blank line is a full empty line. *)
empty-line = line-end, line-end ;

(* =========================
   Block
   ========================= *)

block =
    { comment-line, line-end },
    [ title-line, line-end, [ line-end ] ],
    block-body ;

title-line = "Scenario:", req-ws, { non-newline-char } ;

(* A block is either:
   - a transition block: Given* + When + Then*
   - an event-first transition block: When + Then*
   - an invariant block: Given* + Then*
*)

block-body = given-when-then
           | when-then
           | given-then ;

(* Transition blocks contain exactly one When.
   Invariant blocks contain no When. *)

(* =========================
   Transition / invariant forms
   ========================= *)

given-when-then =
    given-section,
    when-section,
    then-section ;

when-then =
    when-section,
    then-section ;

given-then =
    given-section,
    then-section ;

given-section =
    given-line, line-end,
    { and-given-line, line-end } ;

when-section =
    when-line, line-end ;

(* A then-section contains one Then line, optionally followed by And lines.
   Semantically, each Then/And clause may be interpreted as:
   - a state clause
   - an effect clause
*)

then-section =
    then-line
  | then-line, line-end, and-then-line, { line-end, and-then-line } ;

(* =========================
   Statement lines
   ========================= *)

given-line = "Given", req-ws, clause ;

when-line  = "When",  req-ws, clause ;

then-line  = "Then",  req-ws, then-clause ;

and-given-line = "And", req-ws, clause ;

and-then-line  = "And", req-ws, then-clause ;

(* =========================
   Then clauses
   ========================= *)

(* Syntactically, a then-clause is just a clause.
   Semantically, a then-clause may be interpreted as:
   - a state clause
   - an effect clause
*)

then-clause = clause ;

(* =========================
   Clause (generalised)
   ========================= *)

(* A clause contains two or more bracketed entities, with text between them.
   Optional text may appear before the first entity and after the last.

   Examples:
   - [basket] has [items]
   - the [user] taps the [checkout button]
   - [checkout] applies [promo code] to [basket]
*)

clause =
    [ text ],
    entity,
    text,
    entity,
    { text, entity },
    [ text ] ;

(* Text is any non-bracket, non-newline content.
   It connects entities but is not interpreted by the parser. *)
text = text-char, { text-char } ;

text-char = ? any Unicode character except "[" or "]" or newline ? ;

(* =========================
   Comments
   ========================= *)

(* Comments attach to the block that follows them. *)
comment-line = opt-ws, "#", { non-newline-char } ;

(* =========================
   Entity
   ========================= *)

entity = "[", entity-text, "]" ;

entity-text = { entity-char } ;

entity-char = ? any Unicode character except "]" or newline ? ;

(* =========================
   Whitespace / newlines
   ========================= *)

hspace    = " " | "\t" ;
opt-ws    = { hspace } ;
req-ws    = hspace, { hspace } ;

newline   = "\n" | "\r\n" ;
line-end  = opt-ws, newline ;

non-newline-char = ? any Unicode character except newline ? ;