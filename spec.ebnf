(* =========================
   Top-level structure
   ========================= *)

spec-file =
    block,
    { empty-line, block } ;

(* A blank line is a full empty line. *)
empty-line = line-end, line-end ;

(* =========================
   Block
   ========================= *)

block =
    { comment-line, line-end },
    [ title-line, line-end, [ line-end ] ],
    block-body ;

title-line = "Scenario:", req-ws, { non-newline-char } ;

block-body = given-when-then
           | when-then
           | given-then ;

(* Transition block with preconditions, an event phase, and outcomes. *)
given-when-then =
    given-section,
    when-section,
    then-section ;

(* Transition block with no explicit preconditions. *)
when-then =
    when-section,
    then-section ;

(* Invariant block with conditions and required properties, but no event phase. *)
given-then =
    given-section,
    then-section ;

(*
A given-section contains exactly one Given line, optionally followed by And lines that belong to the precondition phase.
*)
given-section =
    given-line, line-end,
    { and-given-line, line-end } ;

(* A when-section contains exactly one When line, optionally followed by
   And lines that belong to the event phase.

   The When line describes the triggering event.

   And lines may describe preconditions that can only be evaluated after the
   event, and which determine whether the transition takes place.

   Example:
   When the [user] submits [promo code]
   And [promo code] is [invalid]
*)
when-section =
    when-line, line-end,
    { and-when-line, line-end } ;

(* A then-section contains one Then line, optionally followed by And lines.
   Semantically, each Then/And clause may be interpreted as:
   - a state clause, for example: [basket] contains [product]
   - an assertion, for example: [basket total] equals [product price]
*)
then-section =
    then-line
  | then-line, line-end, and-then-line, { line-end, and-then-line } ;

(* =========================
   Statement lines
   ========================= *)

given-line = "Given", req-ws, clause ;

when-line  = "When",  req-ws, when-clause ;

then-line  = "Then",  req-ws, then-clause ;

and-given-line = "And", req-ws, clause ;

and-when-line  = "And", req-ws, when-clause ;

and-then-line  = "And", req-ws, then-clause ;

(* =========================
   When clauses
   ========================= *)

(* A when-clause is a clause interpreted in the event phase. *)
when-clause = clause ;

(* =========================
   Then clauses
   ========================= *)

(* A then-clause is a clause interpreted in the outcome phase. *)
then-clause = clause ;

(* =========================
   Clause (generalised)
   ========================= *)

(* A clause contains two or more bracketed entities, with text between them.
   Optional text may appear before the first entity and after the last.

   Examples:
   - [basket] contains [product]
   - the [user] taps the [checkout button]
   - [user] submits [promo code]
   - [basket total] equals [product price]
   - [basket total] equals [product price] minus [discount amount]
*)

clause =
    [ text ],
    entity,
    text,
    entity,
    { text, entity },
    [ text ] ;

(* Text is any non-bracket, non-newline content.
   It connects entities but is not interpreted by the parser. *)
text = text-char, { text-char } ;

text-char = ? any Unicode character except "[" or "]" or newline ? ;

(* =========================
   Comments
   ========================= *)

(* Comments attach to the block that follows them. *)
comment-line = opt-ws, "#", { non-newline-char } ;

(* =========================
   Entity
   ========================= *)

entity = "[", entity-text, "]" ;

entity-text = { entity-char } ;

entity-char = ? any Unicode character except "]" or newline ? ;

(* =========================
   Whitespace / newlines
   ========================= *)

hspace    = " " | "\t" ;
opt-ws    = { hspace } ;
req-ws    = hspace, { hspace } ;

newline   = "\n" | "\r\n" ;
line-end  = opt-ws, newline ;

non-newline-char = ? any Unicode character except newline ? ;